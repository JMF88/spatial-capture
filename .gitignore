# Python envs / caches
.venv/
.venv-*/
__pycache__/
*.pyc
.ipynb_checkpoints/

# Local capture data & pipeline outputs (large — not for the repo)
data/
**/frames/
**/*_raw/
*.mp4
*.mov
*.MOV
*.insv

# Training runs / checkpoints (commit only a final, small classifier explicitly)
runs/
*.ckpt

# Runtime detection / inference outputs
out/

# Downloaded model weights (re-download on demand; never commit)
*.pt
*.pth
mobileclip*.ts

# Large raw splats live in data/ (ignored above). The demo splat under
# docs/viewer/assets/ IS tracked, so do NOT ignore *.ply / *.splat globally.

# Local working notes and scratch. Untracked by design; nothing here ships.
_private/
**/_sample.*

# OS
.DS_Store
Thumbs.db

# Gated scene assets: commit the .enc ciphertext, never the plaintext capture.
# tools/encrypt_asset.py makes the .enc; the viewer decrypts it in-browser.
docs/viewer/assets/*.ply
docs/viewer/assets/*.spz
docs/viewer/assets/*.sog
docs/viewer/assets/*.splat
docs/viewer/assets/*.ksplat
!docs/viewer/assets/*.enc
# ...but underscore-prefixed files are throwaway probes for exercising the viewer.
# This rule must stay AFTER the un-ignore above: last match wins, and without it the
# un-ignore drags every _probe.ply.enc back into the repo.
docs/viewer/assets/_*
# ...except the physics segmentation (category + bounding boxes, no sensitive content):
# the live viewer fetches it to enable Quake/Blast, so it must ship.
!docs/viewer/assets/_anim_objects.json
# scene.json is fusion output (plaintext scene graph); published deliberately, not by default.
docs/viewer/assets/scene.json
passphrase.txt
*.passphrase

# OCR/detection outputs can carry text read off a real scene; keep them local.
# (The tool's default --out is repo-root titles.json; harden against a stray git add.)
titles.json
**/titles.json
**/detections.json

# Rust/Burn autotune cache
target/
